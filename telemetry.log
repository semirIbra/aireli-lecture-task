aceName":"symmetrical-cod-jj6pj9r4xv4vh5q64","eventName":"DocumentChangeEvent","eventTime":1773608972829,"sessionId":"3e710d00-6afc-4ab1-97b2-dd70b1cd267f1773603764978","machineId":"a0e595c282e6a5a60ae0e86e811164c0eb08e8c9e99d6916b36ec9b19e400d6a","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":13,"operation":"replace","value":"export const registerUser = async (req: Request, res: Response): Promise<void> => {\n  try {\n    const { email, password } = req.body;\n\n    if (!email || !password) {\n      res.status(400).json({ message: \"Email and password required\" });\n      return;\n    }\n\n    const db = await openDb();\n\n    // Check if user already exists\n    const existing = await db.get(\"SELECT * FROM users WHERE email = ?\", email);\n\n    if (existing) {\n      await db.close();\n      res.status(409).json({ message: \"User already exists\" });\n      return;\n    }\n\n    // Create user\n    const createdUser = await createUser({ email, password });\n\n    await db.close();\n\n    res.status(201).json({\n      message: \"User created successfully\",\n      user: createdUser,\n    });\n  } catch (err) {\n    console.error(err);\n    res.status(500).json({ message: \"Internal server error\" });\n  }\n};","rangeOffset":"225","rangeLength":"238","rangestart_line":"6","rangestart_character":"0","rangeend_line":"16","rangeend_character":"2"},{"codespaceName":"symmetrical-cod-jj6pj9r4xv4vh5q64","eventName":"DocumentChangeEvent","eventTime":1773609010877,"sessionId":"3e710d00-6afc-4ab1-97b2-dd70b1cd267f1773603764978","machineId":"a0e595c282e6a5a60ae0e86e811164c0eb08e8c9e99d6916b36ec9b19e400d6a","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":13,"operation":"add","value":"i","rangeOffset":"825","rangeLength":"0","rangestart_line":"27","rangestart_character":"43","rangeend_line":"27","rangeend_character":"43"},{"codespaceName":"symmetr